# Normalize line endings: store as LF, checkout as CRLF on Windows
* text=auto

# Force LF for shell / Python / JS / TS source files
*.py   text eol=lf
*.ts   text eol=lf
*.tsx  text eol=lf
*.js   text eol=lf
*.jsx  text eol=lf
*.css  text eol=lf
*.md   text eol=lf
*.yml  text eol=lf
*.yaml text eol=lf
*.json text eol=lf
*.mjs  text eol=lf
*.sh   text eol=lf

# Binary — no line-ending conversion
*.db      binary
*.sqlite  binary
*.png     binary
*.jpg     binary
*.jpeg    binary
*.gif     binary
*.ico     binary
*.pdf     binary
*.pkl     binary
*.joblib  binary
*.json.gz binary
